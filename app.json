{
  "expo": {
    "name": "mohsynFieldService",
    "slug": "mohsynFieldService",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#00231C",
    "splash": {
      "image": "./src/assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#00231C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/logo.png",
        "backgroundColor": "#00231C"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.mohsyn.fieldservice",
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow mohsynFieldService to use your location."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your team."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow mohsynFieldService to access your microphone."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "37f16c1e-d7c4-4c75-ae1e-ecbdb6bf6202"
      }
    }
  }
}